{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User full name" },
        "photoURL": { "type": "string", "format": "url", "description": "User avatar URL" },
        "role": { "type": "string", "enum": ["admin", "manager", "sales", "finance", "technician", "customer"], "description": "User role" },
        "cpf": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "email", "role"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Client information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "document": { "type": "string", "description": "CPF or CNPJ" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "observations": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "document"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "Vehicle information linked to a customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "plate": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "number" },
        "color": { "type": "string" },
        "vin": { "type": "string" },
        "observations": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "plate", "brand", "model"]
    },
    "Item": {
      "title": "Catalog Item",
      "description": "Product or service in the catalog",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["service", "product", "package", "labor"] },
        "costPrice": { "type": "number" },
        "basePrice": { "type": "number" },
        "unit": { "type": "string", "description": "e.g., hour, unit, km" },
        "active": { "type": "boolean" },
        "ncm": { "type": "string", "description": "Nomenclatura Comum do Mercosul" },
        "ncmDescription": { "type": "string", "description": "Descrição do NCM" },
        "fci": { "type": "string", "description": "Ficha de Conteúdo de Importação" },
        "partCodes": { "type": "array", "items": { "type": "string" }, "description": "Códigos de peça vinculados" },
        "observations": { "type": "string", "description": "Observações adicionais" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "basePrice"]
    },
    "Quote": {
      "title": "Quotation",
      "description": "Quotation details and status",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "quoteNumber": { "type": "string" },
        "title": { "type": "string" },
        "classification": { "type": "string", "enum": ["preventive", "preventive_preview", "corrective", "corrective_preview", "general_overhaul", "general_overhaul_preview", "complementary"] },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "vehicleId": { "type": "string" },
        "vehiclePlate": { "type": "string" },
        "vehicleModel": { "type": "string" },
        "currentKm": { "type": "number" },
        "status": { "type": "string", "enum": ["received", "analyzing", "negotiating", "awaiting_approval", "executing", "finished"] },
        "serviceStatus": { "type": "string", "enum": ["waiting", "in_progress", "testing", "ready", "delivered"] },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "itemId": { "type": "string" },
              "name": { "type": "string" },
              "type": { "type": "string", "enum": ["service", "product", "package", "labor"] },
              "quantity": { "type": "number" },
              "costPrice": { "type": "number" },
              "unitPrice": { "type": "number" },
              "discount": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        },
        "timeline": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "status": { "type": "string", "enum": ["received", "analyzing", "negotiating", "awaiting_approval", "executing", "finished"] },
              "timestamp": { "type": "string", "format": "date-time" },
              "userId": { "type": "string" },
              "userName": { "type": "string" },
              "userRole": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        },
        "subtotal": { "type": "number" },
        "discountTotal": { "type": "number" },
        "taxTotal": { "type": "number" },
        "shippingFee": { "type": "number" },
        "urgencyFee": { "type": "number" },
        "grandTotal": { "type": "number" },
        "validUntil": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "terms": { "type": "string" },
        "observations": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "approvedAt": { "type": "string", "format": "date-time" },
        "approvedBy": { "type": "string" }
      },
      "required": ["customerId", "status", "grandTotal"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "System activity log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "entityType": { "type": "string" },
        "entityId": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "timestamp"]
    },
    "CompanySettings": {
      "title": "Company Settings",
      "description": "Company profile and contact information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logoUrl": { "type": "string", "format": "url" },
        "website": { "type": "string", "format": "url" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Ncm": {
      "title": "NCM",
      "description": "Nomenclatura Comum do Mercosul codes and descriptions",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "NCM Code" },
        "description": { "type": "string", "description": "NCM Description" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "description"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/customers/{customerId}": { "schema": "Customer", "description": "Customer records" },
    "/items/{itemId}": { "schema": "Item", "description": "Catalog items" },
    "/vehicles/{vehicleId}": { "schema": "Vehicle", "description": "Vehicle records" },
    "/quotes/{quoteId}": { "schema": "Quote", "description": "Quotations" },
    "/audit_logs/{logId}": { "schema": "AuditLog", "description": "Audit trail" },
    "/settings/{settingId}": { "schema": "CompanySettings", "description": "System settings" },
    "/ncms/{ncmId}": { "schema": "Ncm", "description": "Saved NCM codes" }
  }
}
